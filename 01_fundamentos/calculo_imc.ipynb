   "source": [
    "# Calcular IMC de uma pessoa"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a57b2b83-35d5-4d40-9cef-f8dc66b0882d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Digite a sua altura:  190\n",
      "Digite o seu peso:  101\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Seu IMC é: 0.0027977839335180054\n"
     ]
    }
   ],
   "source": [
    "altura = float(input('Digite a sua altura: '))\n",
    "peso = float(input('Digite o seu peso: '))\n",
    "\n",
    "altura_ao_quadrado = altura * altura\n",
    "imc = peso / altura_ao_quadrado\n",
    "\n",
    "print(\"Seu IMC é: \" + str(imc))"
   ]
  }
